# Copy to .env.local — NEVER commit .env.local
# Supabase (public — safe for browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Supabase service role — SERVER ONLY, never NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Sentry (optional error tracking)
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug
# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
# AI Chatbot (Epic 3) — disabled by default to avoid surprise API costs.
# Set both to "true" and provide your Anthropic API key to enable.
# Anthropic pricing: ~$0.006–0.018 per message (Sonnet 4.6).
ENABLE_AI_CHAT=false
NEXT_PUBLIC_ENABLE_AI_CHAT=false
ANTHROPIC_API_KEY=sk-ant-your-key-here
